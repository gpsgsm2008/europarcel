<style>
.ep-locker-card {
    border: 1px solid #dee2e6;
    border-radius: 6px;
    overflow: hidden;
    margin-top: 20px;
    font-family: inherit;
    font-size: 14px;
    line-height: 1.5;
    color: #333;
}
.ep-locker-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: #f0f7ff;
    border-bottom: 1px solid #dee2e6;
    font-weight: 600;
    font-size: 15px;
    color: #1a1a1a;
}
.ep-locker-header img {
    flex-shrink: 0;
    height: 24px;
    width: auto;
}
.ep-locker-body {
    padding: 16px;
}
.ep-locker-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 24px;
}
.ep-locker-field {
    display: flex;
    flex-direction: column;
    gap: 2px;
}
.ep-locker-label {
    font-size: 12px;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}
.ep-locker-value {
    font-size: 14px;
    color: #1a1a1a;
}
.ep-locker-map {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    padding: 6px 12px;
    font-size: 13px;
    color: #0d6efd;
    text-decoration: none;
    border: 1px solid #0d6efd;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
}
.ep-locker-map:hover {
    background: #0d6efd;
    color: #fff;
    text-decoration: none;
}
.ep-locker-map svg {
    width: 14px;
    height: 14px;
}
@media (max-width: 576px) {
    .ep-locker-grid {
        grid-template-columns: 1fr;
    }
}
</style>
<div class="ep-locker-card">
    {% set logo_map = {
        'Easybox': 'easybox',
        'Fanbox': 'fanbox',
        'FANbox': 'fanbox',
        'DPD Box': 'dpd',
        'DPD': 'dpd',
        'Cargus': 'cargus'
    } %}
    {% set logo_file = logo_map[carrier_name] is defined ? logo_map[carrier_name] : 'easybox' %}
    <div class="ep-locker-header">
        <img src="extension/europarcel/catalog/view/image/europarcel/{{ logo_file }}.webp" alt="{{ carrier_name }}">
        {{ text_locker_details }} {{ carrier_name }}
    </div>
    <div class="ep-locker-body">
        <div class="ep-locker-grid">
            <div class="ep-locker-field">
                <span class="ep-locker-label">{{ text_locker_name }}</span>
                <span class="ep-locker-value">{{ name }}</span>
            </div>
            <div class="ep-locker-field">
                <span class="ep-locker-label">{{ text_locker_address }}</span>
                <span class="ep-locker-value">{{ address }}</span>
            </div>
            <div class="ep-locker-field">
                <span class="ep-locker-label">{{ text_locker_locality }}</span>
                <span class="ep-locker-value">{{ locality_name }}, {{ county_name }}</span>
            </div>
        </div>
        {% if coordinates.lat is defined and coordinates.long is defined %}
        <a href="https://www.google.com/maps?q={{ coordinates.lat }},{{ coordinates.long }}" target="_blank" rel="noopener" class="ep-locker-map">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{ text_view_on_map }}
        </a>
        {% endif %}
    </div>
</div>

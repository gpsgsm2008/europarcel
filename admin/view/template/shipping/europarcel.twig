{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-shipping" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ cancel }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div id="alert" class="d-none"></div>
    <form id="form-shipping">
      <div class="card mb-3">
        <div class="card-header"><i class="fa-solid fa-key"></i> {{ text_api_integration }}</div>
        <div class="card-body">
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-api-key">{{ entry_api_key }}</label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_api_key" value="{{ shipping_europarcel_api_key }}" placeholder="pk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" id="input-api-key" class="form-control"/>
              <div class="form-text">{{ help_api_key }}</div>
            </div>
          </div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header"><i class="fa-solid fa-gear"></i> {{ text_general_settings }}</div>
        <div class="card-body">
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10 pt-2">
              <div class="form-check form-switch">
                <input type="hidden" name="shipping_europarcel_status" value="0">
                <input type="checkbox" name="shipping_europarcel_status" value="1" id="input-status" class="form-check-input"{% if shipping_europarcel_status %} checked{% endif %}>
              </div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_cod_payment_methods }}</label>
            <div class="col-sm-10">
              <div class="border rounded p-3">
                {% if payment_methods %}
                  {% for method in payment_methods %}
                    <div class="form-check">
                      <input type="checkbox" name="shipping_europarcel_cod_payment_methods[]" value="{{ method.code }}" id="cod-method-{{ method.code }}" class="form-check-input"{% if method.code in shipping_europarcel_cod_payment_methods %} checked{% endif %}>
                      <label for="cod-method-{{ method.code }}" class="form-check-label">{{ method.title }} <small class="text-muted">({{ method.code }})</small></label>
                    </div>
                  {% endfor %}
                {% else %}
                  <p class="text-muted mb-0">{{ text_no_payment_methods }}</p>
                {% endif %}
              </div>
              <div class="form-text">{{ help_cod_payment_methods }}</div>
            </div>
          </div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header"><i class="fa-solid fa-house"></i> {{ text_home_settings }}</div>
        <div class="card-body">
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-status">{{ entry_home_status }}</label>
            <div class="col-sm-10 pt-2">
              <div class="form-check form-switch">
                <input type="hidden" name="shipping_europarcel_home_status" value="0">
                <input type="checkbox" name="shipping_europarcel_home_status" value="1" id="input-home-status" class="form-check-input"{% if shipping_europarcel_home_status %} checked{% endif %}>
              </div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-title">{{ entry_home_title }} <span class="text-danger">*</span></label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_home_title" value="{{ shipping_europarcel_home_title }}" placeholder="{{ entry_home_title }}" id="input-home-title" class="form-control"/>
              <div class="form-text">{{ help_home_title }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-cost">{{ entry_home_cost }} <span class="text-danger">*</span></label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_home_cost" value="{{ shipping_europarcel_home_cost }}" placeholder="{{ entry_home_cost }}" id="input-home-cost" class="form-control"/>
              <div class="form-text">{{ help_home_cost }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-free-home-total">{{ entry_home_free_shiping }} <span class="text-danger">*</span></label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_free_shipping_home_total" value="{{ shipping_europarcel_free_shipping_home_total }}" id="input-free-home-total" class="form-control"/>
              <div class="form-text">{{ help_free_shipping }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-default-courier">{{ entry_home_default_courier }}</label>
            <div class="col-sm-10">
              <select name="shipping_europarcel_home_default_courier" id="input-home-default-courier" class="form-select">
                {% for key, name in home_couriers %}
                  <option value="{{ key }}"{% if shipping_europarcel_home_default_courier == key %} selected{% endif %}>{{ name }}</option>
                {% endfor %}
              </select>
              <div class="form-text">{{ help_home_default_courier }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-tax-class">{{ entry_home_tax_class }}</label>
            <div class="col-sm-10">
              <select name="shipping_europarcel_home_tax_class_id" id="input-home-tax-class" class="form-select">
                <option value="0">{{ text_none }}</option>
                {% for tax_class in tax_classes %}
                  <option value="{{ tax_class.tax_class_id }}"{% if tax_class.tax_class_id == shipping_europarcel_home_tax_class_id %} selected{% endif %}>{{ tax_class.title }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-geo-zone">{{ entry_home_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="shipping_europarcel_home_geo_zone_id" id="input-home-geo-zone" class="form-select">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                  <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == shipping_europarcel_home_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-home-sort-order">{{ entry_home_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_home_sort_order" value="{{ shipping_europarcel_home_sort_order }}" placeholder="{{ entry_home_sort_order }}" id="input-home-sort-order" class="form-control"/>
            </div>
          </div>
        </div>
      </div>
      <div class="card mb-3">
        <div class="card-header"><i class="fa-solid fa-box"></i> {{ text_locker_settings }}</div>
        <div class="card-body">
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-locker-status">{{ entry_locker_status }}</label>
            <div class="col-sm-10 pt-2">
              <div class="form-check form-switch">
                <input type="hidden" name="shipping_europarcel_locker_status" value="0">
                <input type="checkbox" name="shipping_europarcel_locker_status" value="1" id="input-locker-status" class="form-check-input"{% if shipping_europarcel_locker_status %} checked{% endif %}>
              </div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-locker-title">{{ entry_locker_title }} <span class="text-danger">*</span></label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_locker_title" value="{{ shipping_europarcel_locker_title }}" placeholder="{{ entry_locker_title }}" id="input-locker-title" class="form-control"/>
              <div class="form-text">{{ help_locker_title }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-locker-cost">{{ entry_locker_cost }} <span class="text-danger">*</span></label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_locker_cost" value="{{ shipping_europarcel_locker_cost }}" placeholder="{{ entry_locker_cost }}" id="input-locker-cost" class="form-control"/>
              <div class="form-text">{{ help_locker_cost }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-free-locker-total">{{ entry_locker_free_shiping }} <span class="text-danger">*</span></label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_free_shipping_locker_total" value="{{ shipping_europarcel_free_shipping_locker_total }}" id="input-free-locker-total" class="form-control"/>
              <div class="form-text">{{ help_free_shipping }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_locker_couriers }}</label>
            <div class="col-sm-10">
              <div class="border rounded p-3">
                {% for key, name in locker_couriers %}
                  <div class="form-check">
                    <input type="checkbox" name="shipping_europarcel_locker_couriers[]" value="{{ key }}" id="locker-courier-{{ key }}" class="form-check-input"{% if key in shipping_europarcel_locker_couriers %} checked{% endif %}>
                    <label for="locker-courier-{{ key }}" class="form-check-label">{{ name }}</label>
                  </div>
                {% endfor %}
              </div>
              <div class="form-text">{{ help_locker_couriers }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-locker-tax-class">{{ entry_locker_tax_class }}</label>
            <div class="col-sm-10">
              <select name="shipping_europarcel_locker_tax_class_id" id="input-locker-tax-class" class="form-select">
                <option value="0">{{ text_none }}</option>
                {% for tax_class in tax_classes %}
                  <option value="{{ tax_class.tax_class_id }}"{% if tax_class.tax_class_id == shipping_europarcel_locker_tax_class_id %} selected{% endif %}>{{ tax_class.title }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-locker-geo-zone">{{ entry_locker_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="shipping_europarcel_locker_geo_zone_id" id="input-locker-geo-zone" class="form-select">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                  <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == shipping_europarcel_locker_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label" for="input-locker-sort-order">{{ entry_locker_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="shipping_europarcel_locker_sort_order" value="{{ shipping_europarcel_locker_sort_order }}" placeholder="{{ entry_locker_sort_order }}" id="input-locker-sort-order" class="form-control"/>
            </div>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>
<script type="text/javascript"><!--
$('#form-shipping').on('submit', function(e) {
    e.preventDefault();

    var form = $(this);

    $.ajax({
        url: '{{ save|raw }}',
        type: 'post',
        data: form.serialize(),
        dataType: 'json',
        timeout: 15000,
        beforeSend: function() {
            form.find('button[type="submit"]').prop('disabled', true);
        },
        complete: function() {
            form.find('button[type="submit"]').prop('disabled', false);
        },
        success: function(json) {
            $('.alert-dismissible').remove();
            form.find('.is-invalid').removeClass('is-invalid');
            form.find('.invalid-feedback').remove();

            if (json['error']) {
                if (json['error']['warning']) {
                    $('#alert').removeClass('d-none').html('<div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-exclamation-circle"></i> ' + json['error']['warning'] + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                }

                for (var key in json['error']) {
                    var element = $('#input-' + key.replace(/_/g, '-'));
                    if (element.length) {
                        element.addClass('is-invalid');
                        element.after('<div class="invalid-feedback">' + json['error'][key] + '</div>');
                    }
                }
            }

            if (json['success']) {
                $('#alert').removeClass('d-none').html('<div class="alert alert-success alert-dismissible"><i class="fa-solid fa-check-circle"></i> ' + json['success'] + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            $('#alert').removeClass('d-none').html('<div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-exclamation-circle"></i> Could not save settings. Please try again. <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
        }
    });
});
//--></script>
{{ footer }}
